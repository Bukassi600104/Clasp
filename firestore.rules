rules_version = '2';

// Clasp accesses Firestore exclusively through the server (firebase-admin), which
// bypasses these rules. Clients never touch Firestore directly, so a default-deny
// posture is both correct and safe.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
