# ─── Pi Platform ─────────────────────────────────────────────────────────────
# Secret Pi Platform API key from the Pi Developer Portal. SERVER ONLY — never
# expose to the client. When unset, the app runs in a self-contained sandbox
# mode so the UI is fully explorable without Pi infrastructure.
PI_API_KEY=
# Pi Platform API base. Leave default unless Pi instructs otherwise.
PI_API_BASE=https://api.minepi.com
# Domain validation key from the Pi Developer Portal (served at /validation-key.txt).
PI_VALIDATION_KEY=
# App Wallet PRIVATE SEED (Stellar secret key, starts with "S…") for the wallet
# connected to this app in the Pi Developer Portal. SERVER ONLY — this signs the
# custodial App-to-User payouts that release escrowed funds to sellers/buyers.
# When unset, payouts are DISABLED (the app still collects funds but cannot
# release them). Required for the escrow to settle end-to-end.
PI_WALLET_PRIVATE_SEED=
# Pi.init() sandbox flag. "true" ONLY targets the desktop dev environment at
# sandbox.minepi.com. For the app running inside the real Pi Browser it MUST be
# "false" (or unset) — for BOTH Testnet and Mainnet apps. Testnet vs Mainnet is
# chosen by your Pi Developer Portal app registration, not by this flag, and
# PI_API_KEY must be the key of that same app.
NEXT_PUBLIC_PI_SANDBOX=false

# ─── Session ─────────────────────────────────────────────────────────────────
# Strong random secret used to sign the session cookie. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
SESSION_SECRET=

# ─── Firebase (Firestore persistence) ───────────────────────────────────────
# Service-account credentials from the Firebase console
# (Project settings → Service accounts → Generate new private key). SERVER ONLY.
# When unset (and no emulator), the app falls back to the in-memory engine so the
# UI is fully explorable without any Firebase setup.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Paste the private key with literal \n escapes, wrapped in quotes:
#   FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
FIREBASE_PRIVATE_KEY=
# Local dev only — point firebase-admin at the Firestore emulator instead of prod:
#   FIRESTORE_EMULATOR_HOST=localhost:8080
FIRESTORE_EMULATOR_HOST=

# ─── Public API (partners) ───────────────────────────────────────────────────
# Bearer secret guarding POST /api/v1/partners (key issuance). Open when unset.
ADMIN_SECRET=
# Public base URL used to build partner checkout links (defaults to request origin).
# Production domain for Clasp:
APP_URL=https://claspescrow.com

# ─── Cron ────────────────────────────────────────────────────────────────────
# Bearer secret required by the /api/cron/reminders endpoint (set in Vercel Cron).
CRON_SECRET=

# ─── Smart contract (set after Session 1 deploy) ─────────────────────────────
NEXT_PUBLIC_CONTRACT_ADDRESS=
NEXT_PUBLIC_PI_EXPLORER_BASE=https://blockexplorer.minepi.com/mainnet
